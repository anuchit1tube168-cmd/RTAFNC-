# Browser-safe runtime settings for the LIFF and staff frontend.
# Copy to .env on the private deployment server. Do not commit .env.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
LIFF_ID=YOUR_LIFF_ID
LINE_OA_ID=@YOUR_LINE_OA_ID
DEFAULT_SEMESTER=1
DEMO_MODE=true

# Server-side secrets do not belong in this file when it is used by the frontend container.
# Store LINE_CHANNEL_ID, LINE_CHANNEL_SECRET, LINE_CHANNEL_ACCESS_TOKEN,
# TELEGRAM_BOT_TOKEN and SUPABASE_SERVICE_ROLE_KEY in Supabase Function Secrets.

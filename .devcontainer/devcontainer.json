{
  "name": "RTAFNC Portal Preview",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "forwardPorts": [5500],
  "portsAttributes": {
    "5500": {
      "label": "RTAFNC Dashboard",
      "onAutoForward": "openBrowser",
      "protocol": "http"
    }
  },
  "postStartCommand": "nohup python3 tools/preview_server.py --port 5500 >/tmp/rtafnc-preview.log 2>&1 &",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
